# Google Apps Script endpoint (bookings, cron emails, webhooks)
GOOGLE_SHEET_URL=

# Studio admin password
STUDIO_PASSWORD=

# Studio session signing secret (use a long random string)
STUDIO_SECRET=

# Cron job auth secret (set in Vercel cron config)
CRON_SECRET=

# Cal.com webhook signing secret
CAL_WEBHOOK_SECRET=

# Resend API key (email sending)
RESEND_API_KEY=
